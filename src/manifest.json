{
  "manifest_version": 3,
  "name": "AI Arena",
  "version": "4.8.36",
  "version_name": "4.8.36-beta",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: blob: https: http:; media-src 'self' data: blob: https:;"
  },
  "description": "Claude × Gemini × ChatGPT — 一键提问 & 多轮辩论",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "storage",
    "windows",
    "system.display",
    "contextMenus",
    "scripting",
    "declarativeNetRequest",
    "downloads",
    "debugger"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "strip_csp", "enabled": true, "path": "dnr-rules.json" }
    ]
  },
  "host_permissions": [
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.deepseek.com/*",
    "https://www.doubao.com/*",
    "https://tongyi.aliyun.com/*",
    "https://kimi.moonshot.cn/*",
    "https://www.kimi.com/*",
    "https://yuanbao.tencent.com/*",
    "https://grok.com/*",
    "https://www.qianwen.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://tongyi.aliyun.com/*",
        "https://www.qianwen.com/*",
        "https://kimi.moonshot.cn/*",
        "https://www.kimi.com/*",
        "https://yuanbao.tencent.com/*",
        "https://grok.com/*"
      ],
      "js": ["bootstrap-main-world.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["inject-images.js", "content-claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["inject-images.js", "content-gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["inject-images.js", "content-chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["inject-images.js", "content-deepseek.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.doubao.com/*"],
      "js": ["inject-images.js", "content-doubao.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://tongyi.aliyun.com/*", "https://www.qianwen.com/*"],
      "js": ["inject-images.js", "content-qwen.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kimi.moonshot.cn/*", "https://www.kimi.com/*"],
      "js": ["inject-images.js", "content-kimi.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://yuanbao.tencent.com/*"],
      "js": ["inject-images.js", "content-yuanbao.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["inject-images.js", "content-grok.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AI Arena"
  }
}
